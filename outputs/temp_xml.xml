="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex"><w:body><w:p><w:pPr><w:spacing w:after="400"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">Según lo aprobado por la Junta directiva de Counterpart International el 9 de noviembre de 2023</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:before="200" w:after="200"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="24"/><w:szCs w:val="24"/></w<w:t xml:space="preserve">ESTATUTOS</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="24"/><w:szCs w:val="24"/></w<w:t xml:space="preserve">DE</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:u w:val="single"/></w<w:t xml:space="preserve">COUNTERPART INTERNATIONAL, INC.</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="600"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">(Una corporación sin ánimo de lucro de Nueva York)</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:before="400" w:after="200"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="24"/><w:szCs w:val="24"/></w<w:t xml:space="preserve">ARTÍCULO I</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="400"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/><w:u w:val="single"/></w<w:t xml:space="preserve">Miembros</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="400"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">SECCIÓN 1. Sin miembros. </w:t>/w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/><w:u w:val="single"/></w<w:t xml:space="preserve">Counterpart International, Inc. (la </w:t>/w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve"> «Corporación») no tendrá miembros.</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:before="400" w:after="200"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="24"/><w:szCs w:val="24"/></w<w:t xml:space="preserve">ARTÍCULO II</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="400"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/><w:u w:val="single"/></w<w:t xml:space="preserve">Junta directiva</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">SECCIÓN 1. Facultades </w:t>/w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/><w:u w:val="single"/></w<w:t xml:space="preserve">generales de los directores.</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="400"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">La Junta directiva de la Corporación (la «Junta») ejercerá su poder y autoridad para administrar y dirigir la totalidad de los negocios y asuntos de la Corporación. La Junta tiene la autoridad para nombrar o destituir al Director Ejecutivo de Counterpart International, Inc. y a los Directores Ejecutivos de sus filiales, sujeto a la recomendación del Comité de la Junta de dicha filial. La Junta tendrá plena discreción y autoridad para participar en cualquier negocio, adoptar cualquier política y tomar cualquier decisión que esté en conformidad con el Certificado de constitución, los presentes Estatutos y las leyes vigentes, según sean modificados periódicamente.</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">SECCIÓN 2. </w:t>/w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/><w:u w:val="single"/></w<w:t xml:space="preserve">Número de directores.</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="400"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">Esta Corporación tendrá no menos de tres (3) y no más de dieciocho (18) directores. El Presidente/Director Ejecutivo de la Corporación será un miembro ex officio de la Junta sin requisito de elección y sin derecho a voto. Este cargo no computará para el número total de directores a los efectos de esta sección.</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">SECCIÓN 3. </w:t>/w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/><w:u w:val="single"/></w<w:t xml:space="preserve">Periodo del cargo.</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="400"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">El periodo estándar del cargo de cada director será de tres (3) años. Los periodos de los directores serán escalonados de manera que aproximadamente un tercio de los directores sea elegido anualmente. Los directores no ejercerán más de tres periodos consecutivos de tres años, salvo en circunstancias excepcionales</w:t>/w:t></w:r></w:p><w:p><w:pPr><w:spacing w:before="600"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="000000"/><w:sz w:val="22"/><w:szCs w:val="22"/></w<w:t xml:space="preserve">1</w:t>/w:t></w:r></w:p><w:sectPr><w:pgSz w:w="12240" w:h="15840" w:orient="portrait"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:pgNumType/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>